# Variáveis de Ambiente - EXEMPLO
# Copie este arquivo para ".env.local" e preencha com suas credenciais

# ========================================
# SUPABASE (Banco de Dados + Auth + Storage)
# ========================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...seu_token_aqui...

# ========================================
# GOOGLE DRIVE (Upload de Documentos)
# ========================================
VITE_GOOGLE_DRIVE_FOLDER_ID=seu_folder_id_aqui
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-email@seu-projeto.iam.gserviceaccount.com

# ========================================
# Nota Importante:
# ========================================
# 1. Obtenha VITE_SUPABASE_URL em: Supabase Dashboard → Settings → API
# 2. Obtenha VITE_SUPABASE_ANON_KEY em: Supabase Dashboard → Settings → API → anon key
# 3. Para Google Drive:
#    - VITE_GOOGLE_DRIVE_FOLDER_ID: ID da pasta "Documentos Clientes" no Drive
#    - VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL: Email da Service Account criada
#    - Coloque o arquivo google-service-account.json na pasta credentials/
# 4. NUNCA commit .env.local com valores reais (contém dados sensíveis)
# 5. Use este arquivo como template para novos ambientes
