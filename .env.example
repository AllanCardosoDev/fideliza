# Variáveis de Ambiente - EXEMPLO
# Copie este arquivo para ".env.local" e preencha com suas credenciais

# ========================================
# SUPABASE (Banco de Dados + Auth + Storage)
# ========================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...seu_token_aqui...

# ========================================
# DEPLOY (Hostinger)
# ========================================
# Deixe vazio ("/") se o site estiver na raiz do domínio (ex: meudominio.com.br)
# Use o caminho do subdiretório se o site estiver em uma subpasta
# Exemplos: VITE_BASE_PATH=/  ou  VITE_BASE_PATH=/fideliza/
VITE_BASE_PATH=/

# ========================================
# Nota Importante:
# ========================================
# 1. Obtenha VITE_SUPABASE_URL em: Supabase Dashboard → Settings → API
# 2. Obtenha VITE_SUPABASE_ANON_KEY em: Supabase Dashboard → Settings → API → anon key
# 3. NUNCA commit .env.local com valores reais (contém dados sensíveis)
# 4. Use este arquivo como template para novos ambientes
# 5. Após alterar variáveis, execute "npm run build" novamente antes de enviar para o servidor

