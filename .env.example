# Variáveis de Ambiente - EXEMPLO
# Copie este arquivo para ".env.local" e preencha com suas credenciais

# ========================================
# SUPABASE (Banco de Dados + Auth + Storage)
# ========================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...seu_token_aqui...

# ========================================
# BACKBLAZE B2 (Upload de Documentos)
# Usado APENAS no servidor — nunca exposto ao browser
# ========================================
B2_KEY_ID=seu_key_id_aqui
B2_APPLICATION_KEY=sua_application_key_aqui
B2_BUCKET_NAME=documentos-clientes
B2_ENDPOINT=https://s3.us-west-005.backblazeb2.com
B2_BUCKET_REGION=us-west-005

# ========================================
# Nota Importante:
# ========================================
# 1. Obtenha VITE_SUPABASE_URL em: Supabase Dashboard → Settings → API
# 2. Obtenha VITE_SUPABASE_ANON_KEY em: Supabase Dashboard → Settings → API → anon key
# 3. Para Backblaze B2:
#    - B2_KEY_ID e B2_APPLICATION_KEY: Backblaze Dashboard → App Keys
#    - B2_ENDPOINT: Backblaze Dashboard → Buckets → Endpoint (ex: s3.us-west-005.backblazeb2.com)
#    - B2_BUCKET_REGION: parte do endpoint (ex: us-west-005)
# 4. NUNCA commite .env com valores reais (contém dados sensíveis)
# 5. Use este arquivo como template para novos ambientes
